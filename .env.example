# ============================================
# INDUSTRY360 MES Platform - Environment Config
# ============================================

# Application
NODE_ENV=development
APP_NAME=INDUSTRY360 MES Platform
APP_VERSION=1.0.0

# API
API_PORT=3001
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=INDUSTRY360 MES

# Database - PostgreSQL
DATABASE_URL=postgresql://mes_user:mes_password@localhost:5432/industry360_mes?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=industry360_mes
DB_USER=mes_user
DB_PASSWORD=mes_password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# InfluxDB (Time-series)
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=industry360
INFLUX_BUCKET=mes_timeseries

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@industry360.sa
SMTP_PASSWORD=your-email-password
EMAIL_FROM=INDUSTRY360 MES <noreply@industry360.sa>

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp (Twilio)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# MQTT Broker
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=mes_broker
MQTT_PASSWORD=mqtt_password
MQTT_CLIENT_ID=industry360-mes

# OPC UA
OPCUA_ENDPOINT=opc.tcp://localhost:4840

# File Storage (MinIO/S3)
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=industry360-mes

# AWS S3 (Production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# AI/OpenAI
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Multi-tenancy
DEFAULT_TENANT=industry360
ALLOW_REGISTRATION=false

# SAP Integration
SAP_BASE_URL=
SAP_CLIENT=100
SAP_USERNAME=
SAP_PASSWORD=

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
