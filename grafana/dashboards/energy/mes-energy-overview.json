        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT ROUND(COALESCE(SUM(t.value),0)::numeric,1) AS value FROM energy_readings t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"timestamp\") AND ('$factory' = '' OR f.code = '$factory') AND ('$machine' = '' OR t.\"machineId\" = '$machine')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
