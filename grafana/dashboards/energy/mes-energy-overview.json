            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT $__timeGroupAlias(t.\"timestamp\",$__interval), AVG(t.\"powerKw\") AS \"kW\" FROM energy_readings t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"timestamp\") AND ('$factory' = '' OR f.code = '$factory') AND ('$machine' = '' OR t.\"machineId\" = '$machine') GROUP BY 1 ORDER BY 1"
