    {
      "id": 7,
      "title": "Per-Factory Rollup",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT f.name AS \"Factory\", ROUND(AVG(o.oee)::numeric,1) AS \"OEE %\", SUM(o.\"totalOutput\") AS \"Output\", (SELECT COUNT(*) FROM ncrs n WHERE n.\"factoryId\"=f.id AND n.status NOT IN ('RESOLVED','CLOSED')) AS \"Open NCRs\", (SELECT COUNT(*) FROM maintenance_wos mw WHERE mw.\"factoryId\"=f.id AND mw.status IN ('OPEN','ASSIGNED','IN_PROGRESS') AND mw.\"deletedAt\" IS NULL) AS \"Open Maint\" FROM oee_records o JOIN factories f ON f.id=o.\"factoryId\" WHERE $__timeFilter(o.\"recordDate\") GROUP BY f.id, f.name ORDER BY 2 DESC"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
