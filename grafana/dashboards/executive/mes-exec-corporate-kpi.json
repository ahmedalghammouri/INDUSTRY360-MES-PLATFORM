            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT COALESCE(AVG(oee),0) AS value FROM oee_records t WHERE $__timeFilter(t.\"recordDate\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
