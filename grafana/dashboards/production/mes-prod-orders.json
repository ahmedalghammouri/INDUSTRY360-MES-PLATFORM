    {
      "id": 8,
      "title": "Active Work Orders",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT t.\"orderNumber\" AS \"WO #\", k.name AS \"Product\", t.status AS \"Status\", t.priority AS \"Priority\", t.\"plannedQty\" AS \"Planned\", t.\"plannedEnd\" AS \"Planned End\" FROM work_orders t JOIN factories f ON f.id=t.\"factoryId\" LEFT JOIN skus k ON k.id=t.\"skuId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.status IN ('PLANNED','RELEASED','IN_PROGRESS','ON_HOLD') AND t.\"deletedAt\" IS NULL ORDER BY t.\"plannedEnd\" LIMIT 50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
