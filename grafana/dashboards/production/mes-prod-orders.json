      "id": 7,
      "title": "WO Completions (trend)",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT $__timeGroupAlias(t.\"actualEnd\",$__interval), COUNT(*) AS \"Completed\" FROM work_orders t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"actualEnd\") AND ('$factory' = '' OR f.code = '$factory') GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
