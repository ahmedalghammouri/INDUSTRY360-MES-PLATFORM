          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT CASE WHEN SUM(quantity)>0 THEN ROUND(100.0*SUM(\"goodQuantity\")/SUM(quantity),1) ELSE 0 END AS value FROM batch_records t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"startTime\") AND ('$factory' = '' OR f.code = '$factory')"
