          },
          "rawSql": "SELECT t.\"batchNumber\" AS \"Batch\", k.name AS \"Product\", t.status AS \"Status\", t.quantity AS \"Qty\", t.\"goodQuantity\" AS \"Good\", t.\"scrapQuantity\" AS \"Scrap\", t.\"startTime\" AS \"Start\" FROM batch_records t JOIN factories f ON f.id=t.\"factoryId\" LEFT JOIN skus k ON k.id=t.\"skuId\" WHERE ('$factory' = '' OR f.code = '$factory') ORDER BY t.\"startTime\" DESC NULLS LAST LIMIT 50"
