          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT $__timeGroupAlias(t.\"startTime\",$__interval), SUM(t.\"durationMinutes\") AS \"Downtime\" FROM downtime_events t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"startTime\") AND ('$factory' = '' OR f.code = '$factory') AND ('$machine' = '' OR t.\"machineId\" = '$machine') GROUP BY 1 ORDER BY 1"
        }
      ],
