      "id": 1,
      "title": "Total Downtime (min)",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT COALESCE(SUM(t.\"durationMinutes\"),0) AS value FROM downtime_events t JOIN factories f ON f.id = t.\"factoryId\" WHERE $__timeFilter(t.\"startTime\") AND ('$factory' = '' OR f.code = '$factory') AND ('$machine' = '' OR t.\"machineId\" = '$machine')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
