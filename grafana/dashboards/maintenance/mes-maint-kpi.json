  "panels": [
    {
      "id": 1,
      "title": "Open WOs",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM maintenance_wos t JOIN factories f ON f.id = t.\"factoryId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.\"deletedAt\" IS NULL AND t.status IN ('OPEN','ASSIGNED','IN_PROGRESS')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "id": 2,
      "title": "Overdue PM",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM maintenance_wos t JOIN factories f ON f.id = t.\"factoryId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.\"deletedAt\" IS NULL AND t.type='PREVENTIVE' AND t.\"dueDate\" < NOW() AND t.status NOT IN ('COMPLETED','CANCELLED')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "id": 3,
      "title": "Completion %",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT CASE WHEN COUNT(*)>0 THEN ROUND(100.0*COUNT(*) FILTER (WHERE t.status='COMPLETED')/COUNT(*),1) ELSE 0 END AS value FROM maintenance_wos t JOIN factories f ON f.id = t.\"factoryId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.\"deletedAt\" IS NULL"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "id": 4,
      "title": "Maintenance Cost",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT ROUND(COALESCE(SUM(t.\"totalCost\"),0)::numeric,0) AS value FROM maintenance_wos t JOIN factories f ON f.id = t.\"factoryId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.\"deletedAt\" IS NULL AND $__timeFilter(t.\"createdAt\")"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "id": 5,
      "title": "Cost Trend",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "mes_postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "mes_postgres"
          },
          "rawSql": "SELECT $__timeGroupAlias(t.\"createdAt\",$__interval), SUM(t.\"totalCost\") AS \"Cost\" FROM maintenance_wos t JOIN factories f ON f.id = t.\"factoryId\" WHERE ('$factory' = '' OR f.code = '$factory') AND t.\"deletedAt\" IS NULL AND $__timeFilter(t.\"createdAt\") GROUP BY 1 ORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisLabel": "",
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      }
    }
  ]
}
