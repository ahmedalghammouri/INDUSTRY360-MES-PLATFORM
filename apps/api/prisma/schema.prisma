// ============================================================
// SHIFTS
// ============================================================

model ShiftTemplate {
  id                     String   @id @default(uuid())
  factoryId              String
  code                   String
  name                   String
  nameAr                 String?
  startTime              String // HH:mm (24h)
  endTime                String // HH:mm (24h)
