  cleaningMinutes        Int      @default(30)
  days                   Json // [0=Sun,1=Mon,...,6=Sat]
  targetQtyPerShift      Int? // default production target per shift per line (boxes/packs)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  factory   Factory         @relation(fields: [factoryId], references: [id])
  instances ShiftInstance[]

  @@unique([factoryId, code])
  @@map("shift_templates")
}

model ShiftInstance {
  id              String      @id @default(uuid())
  factoryId       String
  shiftTemplateId String
  lineId          String?
  shiftDate       DateTime // the calendar date (start date)
  startTime       DateTime
  endTime         DateTime?
  targetQty       Int?
  actualQty       Int         @default(0)
  goodQty         Int         @default(0)
  scrapQty        Int         @default(0)
  oee             Float?
  availability    Float?
  performance     Float?
  quality         Float?
  downtimeMinutes Float       @default(0)
  plannedDowntime Float       @default(0)
  operatorId      String?
  supervisorId    String?
  handoverNotes   String?
  status          ShiftStatus @default(PLANNED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  factory       Factory              @relation(fields: [factoryId], references: [id])
  shiftTemplate ShiftTemplate        @relation(fields: [shiftTemplateId], references: [id])
  line          ProductionLine?      @relation(fields: [lineId], references: [id])
  operator      User?                @relation("ShiftOperator", fields: [operatorId], references: [id])
  supervisor    User?                @relation("ShiftSupervisor", fields: [supervisorId], references: [id])
  workOrders    WorkOrder[]
  stateRecords  MachineStateRecord[]
  oeeRecords    OEERecord[]

  @@index([factoryId, shiftDate])
  @@map("shift_instances")
}

enum ShiftStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

// ============================================================
// OEE ENGINE — MACHINE STATE & DOWNTIME
// ============================================================

model MachineStateRecord {
  id              String       @id @default(uuid())
  factoryId       String
  machineId       String
  shiftInstanceId String?
  workOrderId     String?
  skuId           String?
  state           MachineState
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Float? // calculated on endTime set
  isPlannedStop   Boolean      @default(false)
  downtimeCauseId String?
  notes           String?
  source          String       @default("SYSTEM") // SYSTEM, OPERATOR, MAINTENANCE

  factory       Factory        @relation(fields: [factoryId], references: [id])
  machine       Machine        @relation(fields: [machineId], references: [id])
  shiftInstance ShiftInstance? @relation(fields: [shiftInstanceId], references: [id])
  downtimeCause DowntimeCause? @relation(fields: [downtimeCauseId], references: [id])

  @@index([factoryId, startTime])
  @@index([machineId, startTime])
  @@map("machine_state_records")
}

// DOWNTIME CAUSE (NCC pre-loaded codes per machine)
model DowntimeCause {
  id        String           @id @default(uuid())
  factoryId String
  machineId String? // null = applicable to all machines
  code      String
  name      String
  nameAr    String?
  category  DowntimeCategory
  isPlanned Boolean          @default(false)
  sortOrder Int              @default(0)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  // 3-level PDM tree: level 1 = top category, 2 = sub-category, 3 = specific reason (leaf)
  level    Int             @default(3)
  parentId String?
  parent   DowntimeCause?  @relation("DowntimeCauseTree", fields: [parentId], references: [id], onDelete: SetNull)
  children DowntimeCause[] @relation("DowntimeCauseTree")

  factory        Factory              @relation(fields: [factoryId], references: [id])
  machine        Machine?             @relation(fields: [machineId], references: [id])
  stateRecords   MachineStateRecord[]
  downtimeEvents DowntimeEvent[]

  @@index([factoryId])
  @@index([machineId])
  @@index([parentId])
  @@map("downtime_causes")
}

enum DowntimeCategory {
  MECHANICAL
  ELECTRICAL
  PROCESS
  MATERIAL
  OPERATOR
  CHANGEOVER
  UTILITY
  QUALITY
  PLANNED_MAINTENANCE
  PLANNED_CLEANING
  PLANNED_BREAK
  EXTERNAL
  OTHER
}

// DOWNTIME EVENT (logged, can be linked to maintenance WO)
// ISA-95 standardized 5-category downtime reason codes
enum DowntimeReasonCode {
  PLANNED_MAINTENANCE // PM, calibration, CIP — excluded from OEE Availability loss
  CHANGEOVER // format/product change — planned stop, reduces net production time
  UNPLANNED_BREAKDOWN // mechanical / electrical / process failure → Availability Loss
  MICRO_STOP // <5 min interruption → Performance Loss (speed loss category)
  STARVED // waiting for upstream material or step to deliver
  BLOCKED // waiting for downstream step / buffer to clear
  EXTERNAL // utilities, power, external cause beyond line control
}

model DowntimeEvent {
  id                   String             @id @default(uuid())
  factoryId            String
  machineId            String
  workCenterId         String? // ISA-95 WorkCenter link (replaces raw machine where routing is used)
  workOrderId          String?
  shiftInstanceId      String?
  causeId              String?
  operatorId           String? // operator on shift who reported / triggered
  reason               String? // free text override / root cause description
  category             DowntimeCategory
  reasonCode           DowntimeReasonCode @default(UNPLANNED_BREAKDOWN)
  startTime            DateTime
  endTime              DateTime?
  durationMinutes      Float?
  affectsOEE           Boolean            @default(true) // false for PLANNED_MAINTENANCE, EXTERNAL
  isPlanned            Boolean            @default(false)
  reportedById         String?
  acknowledged         Boolean            @default(false)
  acknowledgedById     String?
  acknowledgedAt       DateTime?
  maintenanceWOId      String?
  schedulingImpactMins Float? // computed cascade delay pushed to dependent WO steps
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  factory    Factory        @relation(fields: [factoryId], references: [id])
  machine    Machine        @relation(fields: [machineId], references: [id])
  workCenter WorkCenter?    @relation("WCDowntimes", fields: [workCenterId], references: [id])
  workOrder  WorkOrder?     @relation(fields: [workOrderId], references: [id])
  cause      DowntimeCause? @relation(fields: [causeId], references: [id])
  operator   User?          @relation("DowntimeOperator", fields: [operatorId], references: [id])

  @@index([factoryId, startTime])
  @@index([machineId, startTime])
  @@index([workCenterId, startTime])
  @@index([reasonCode])
  @@map("downtime_events")
}

// OEE RECORD (calculated and stored for reporting)
model OEERecord {
  id                   String   @id @default(uuid())
  factoryId            String
  machineId            String
  shiftInstanceId      String?
  recordDate           DateTime
  shiftCode            String?
  skuId                String?
  plannedProductionMin Float // minutes
  actualProductionMin  Float // minutes (excl planned stops)
  uptimeMin            Float // minutes actually running
  downtimeMin          Float // minutes unplanned downtime
  plannedDowntimeMin   Float    @default(0)
  totalOutput          Int
  goodOutput           Int
  scrapOutput          Int      @default(0)
  idealCycleTime       Float? // seconds per unit
  availability         Float // %
  performance          Float // %
  quality              Float // %
  oee                  Float // %
  calculatedAt         DateTime @default(now())

  factory       Factory        @relation(fields: [factoryId], references: [id])
  machine       Machine        @relation(fields: [machineId], references: [id])
  shiftInstance ShiftInstance? @relation(fields: [shiftInstanceId], references: [id])

  @@index([factoryId, recordDate])
  @@index([machineId, recordDate])
  @@map("oee_records")
}

// MACHINE RUNTIME HOURS (for PM scheduling)
model MachineRuntimeHours {
  id              String   @id @default(uuid())
  machineId       String
  factoryId       String
  recordDate      DateTime @db.Date
  dailyHours      Float
  cumulativeHours Float
  source          String   @default("CALCULATED") // CALCULATED, MANUAL
  createdAt       DateTime @default(now())

  machine Machine @relation(fields: [machineId], references: [id])

  @@unique([machineId, recordDate])
  @@map("machine_runtime_hours")
}

// ============================================================
