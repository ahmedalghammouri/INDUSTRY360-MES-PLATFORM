// ============================================================
// ENERGY MANAGEMENT
// ============================================================

model EnergyMeter {
  id          String     @id @default(uuid())
  factoryId   String
  machineId   String? // null = area-level meter
  areaId      String?
  meterNumber String
  name        String
  type        EnergyType
  unit        String // kWh, m3, L, kW
  brand       String?
  location    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  factory   Factory         @relation(fields: [factoryId], references: [id])
  machine   Machine?        @relation(fields: [machineId], references: [id])
  area      Area?           @relation(fields: [areaId], references: [id])
  readings  EnergyReading[]
  summaries EnergySummary[]

  @@unique([factoryId, meterNumber])
  @@map("energy_meters")
}

enum EnergyType {
  ELECTRICAL
  NATURAL_GAS
  COMPRESSED_AIR
  WATER
  STEAM
  CHILLED_WATER
}

model EnergyReading {
  id              String   @id @default(uuid())
  meterId         String
  factoryId       String
  workCenterId    String? // WorkCenter active at reading time (for production context)
  workOrderId     String? // WO active at reading time
  machineId       String? // specific machine if meter is machine-level
  shiftInstanceId String?
  timestamp       DateTime
  value           Float // cumulative kWh / m³ (delta calculated at aggregation)
  powerKw         Float? // instantaneous power draw at this timestamp
  unit            String
  machineState    String? // snapshot: RUNNING | IDLE | BREAKDOWN | PLANNED_STOP
  source          String   @default("AUTO") // AUTO (from IoT), MANUAL
  quality         String   @default("GOOD")
  createdAt       DateTime @default(now())

  factory    Factory     @relation(fields: [factoryId], references: [id])
  meter      EnergyMeter @relation(fields: [meterId], references: [id])
  workCenter WorkCenter? @relation("WCEnergyReadings", fields: [workCenterId], references: [id])

  @@index([meterId, timestamp])
  @@index([factoryId, timestamp])
  @@index([workOrderId])
  @@index([workCenterId, timestamp])
  @@map("energy_readings")
}

// Aggregated energy consumption per Work Order (computed on WO close)
model EnergyWOSummary {
  id            String   @id @default(uuid())
  workOrderId   String   @unique
  factoryId     String
  totalKwh      Float // total electrical energy over WO duration
  runningKwh    Float    @default(0) // energy while machineState = RUNNING
  idleKwh       Float    @default(0) // energy while machineState = IDLE (waste)
  downtimeKwh   Float    @default(0) // energy while machineState = BREAKDOWN (waste)
  kwhPerUnit    Float? // totalKwh / qtyProduced
  kwhPerKgBatch Float? // totalKwh / batchSize (kg)
  peakPowerKw   Float? // maximum instantaneous power recorded
  avgPowerKw    Float? // average power over run period
  anomalyCount  Int      @default(0) // #readings where powerKw > threshold during idle/down
  computedAt    DateTime @default(now())

  factory   Factory   @relation(fields: [factoryId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@map("energy_wo_summaries")
}

model EnergySummary {
  id               String       @id @default(uuid())
  meterId          String
  factoryId        String
  periodType       EnergyPeriod
  periodStart      DateTime
  periodEnd        DateTime
  totalConsumption Float
  unit             String
  cost             Float?
  costCurrency     String       @default("SAR")
  productionQty    Float?
  specificEnergy   Float? // kWh/unit
  createdAt        DateTime     @default(now())

  factory Factory     @relation(fields: [factoryId], references: [id])
  meter   EnergyMeter @relation(fields: [meterId], references: [id])

  @@index([meterId, periodStart])
  @@map("energy_summaries")
}

enum EnergyPeriod {
  HOURLY
  SHIFT
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================================
// IIIOT — LOGICAL CONNECTIVITY LAYER
// ============================================================

model Device {
  id               String    @id @default(uuid())
  factoryId        String
  machineId        String?
  name             String
  deviceCode       String    @unique
  type             String // PLC, HMI, GATEWAY, SENSOR, METER, DRIVE
  protocol         String // OPCUA, MODBUS, MQTT, FINS, S7, HTTP
  ipAddress        String?
  port             Int?
  connectionString String?
  status           String    @default("DISCONNECTED") // CONNECTED, DISCONNECTED, ERROR
  lastSeenAt       DateTime?
  firmware         String?
  config           Json?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  factory        Factory         @relation(fields: [factoryId], references: [id])
  machine        Machine?        @relation(fields: [machineId], references: [id])
  tagDefinitions TagDefinition[]

  @@index([factoryId])
  @@map("devices")
}

model TagDefinition {
  id                   String      @id @default(uuid())
  factoryId            String
  machineId            String?
  deviceId             String?
  code                 String
  name                 String
  description          String?
  dataType             TagDataType
  unit                 String?
  minValue             Float?
  maxValue             Float?
  scaleFactor          Float?
  offset               Float?
  tagType              TagType     @default(MEASUREMENT)
  historizationEnabled Boolean     @default(true)
  historizationRateSec Int         @default(60)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  factory          Factory           @relation(fields: [factoryId], references: [id])
  machine          Machine?          @relation(fields: [machineId], references: [id])
  device           Device?           @relation(fields: [deviceId], references: [id])
  currentValue     TagCurrentValue?
  alarmDefinitions AlarmDefinition[]

  @@unique([factoryId, code])
  @@map("tag_definitions")
}

enum TagDataType {
  BOOL
  INT
  FLOAT
  STRING
  TIMESTAMP
}

enum TagType {
  STATUS
  COUNTER
  MEASUREMENT
  SETPOINT
  ALARM
  EVENT
  ENERGY
}

model TagCurrentValue {
  id        String     @id @default(uuid())
  tagId     String     @unique
  factoryId String
  value     String
  quality   TagQuality @default(GOOD)
  timestamp DateTime   @default(now())

  tag TagDefinition @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@map("tag_current_values")
}

enum TagQuality {
  GOOD
  BAD
  UNCERTAIN
  NOT_CONNECTED
}

model AlarmDefinition {
  id           String        @id @default(uuid())
  factoryId    String
  tagId        String?
  code         String
  name         String
  severity     AlarmSeverity @default(HIGH)
  category     String        @default("PROCESS")
  condition    String? // GT, LT, EQ, NEQ
  threshold    Float?
  deadband     Float?
  delaySeconds Int           @default(0)
  autoAck      Boolean       @default(false)
  notifyRoles  Json          @default("[]")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  factory Factory        @relation(fields: [factoryId], references: [id])
  tag     TagDefinition? @relation(fields: [tagId], references: [id])
  events  AlarmEvent[]

  @@map("alarm_definitions")
}

enum AlarmSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

model AlarmEvent {
  id                String        @id @default(uuid())
  factoryId         String
  alarmDefinitionId String?
  machineId         String?
  code              String
  description       String
  severity          AlarmSeverity
  category          String?
  value             Float?
  threshold         Float?
  triggeredAt       DateTime
  acknowledgedAt    DateTime?
  acknowledgedById  String?
  resolvedAt        DateTime?
  resolvedById      String?
  durationMinutes   Float?
  notes             String?
  metadata          Json?

  factory         Factory          @relation(fields: [factoryId], references: [id])
  machine         Machine?         @relation(fields: [machineId], references: [id])
  alarmDefinition AlarmDefinition? @relation(fields: [alarmDefinitionId], references: [id])

  @@index([factoryId, triggeredAt])
  @@index([machineId, triggeredAt])
  @@map("alarm_events")
}

// ============================================================
// USERS & RBAC — FACTORY-SCOPED
// ============================================================

model User {
  id                  String    @id @default(uuid())
  enterpriseId        String
  factoryId           String? // null = SUPER_ADMIN (access to all factories)
  email               String    @unique
  name                String
  nameAr              String?
  passwordHash        String
  role                UserRole  @default(OPERATOR)
  department          String?
  jobTitle            String?
  phone               String?
  avatarUrl           String?
  language            String    @default("en")
  timezone            String    @default("Asia/Riyadh")
  isActive            Boolean   @default(true)
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedAt            DateTime?
  notifyEmail         Boolean   @default(true)
  notifyWhatsapp      Boolean   @default(false)
  notifySMS           Boolean   @default(false)
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  enterprise    Enterprise     @relation(fields: [enterpriseId], references: [id])
  factory       Factory?       @relation(fields: [factoryId], references: [id])
  sessions      UserSession[]
  auditLogs     AuditLog[]
  notifications Notification[]

  // Work Order relations
  woCreated         WorkOrder[]     @relation("WOCreatedBy")
  woStarted         WorkOrder[]     @relation("WOStartedBy")
  woCompleted       WorkOrder[]     @relation("WOCompletedBy")
  woOperator        WorkOrder[]     @relation("WOOperator")
  woSupervisor      WorkOrder[]     @relation("WOSupervisor")
  shiftAsOperator   ShiftInstance[] @relation("ShiftOperator")
  shiftAsSupervisor ShiftInstance[] @relation("ShiftSupervisor")

  // Quality
  inspections  InspectionResult[] @relation("InspectionInspector")
  ncrsDetected NCR[]              @relation("NCRDetectedBy")
  capaAssigned CAPA[]             @relation("CAPAAssignedTo")

  // Maintenance
  maintAssigned    MaintenanceWO[]    @relation("MaintAssignedTo")
  maintRequested   MaintenanceWO[]    @relation("MaintRequestedBy")
  pmTasksAssigned  PMTask[]           @relation("PMTaskAssignedTo")
  sparePartsIssued MaintWOSparePart[] @relation("SpareIssuedBy")

  // Inventory & Traceability
  stockMovements StockMovement[] @relation("StockMovementBy")
  traceEvents    TraceEvent[]    @relation("TracePerformedBy")

  // Recipes
  approvedRecipes        Recipe[]        @relation("RecipeApprovedBy")
  // Downtime operator relation
  operatedDowntimes      DowntimeEvent[] @relation("DowntimeOperator")
  jobOrdersAsOperator    JobOrder[]      @relation("JOOperator")
  scrapLogsAsOperator    ScrapLog[]      @relation("ScrapLogOperator")
  changeRequestsRaised   ChangeRequest[] @relation("CRRequestedBy")
  changeRequestsReviewed ChangeRequest[] @relation("CRReviewedBy")

  @@index([enterpriseId])
  @@index([factoryId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  FACTORY_ADMIN
  PLANT_MANAGER
  PRODUCTION_MANAGER
  PRODUCTION_SUPERVISOR
  QUALITY_MANAGER
  QUALITY_ENGINEER
  MAINTENANCE_MANAGER
  MAINTENANCE_TECHNICIAN
  ENERGY_MANAGER
  OPERATOR
  VIEWER
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  userAgent    String?
  ipAddress    String?
  factoryId    String? // which factory context was active
  isRevoked    Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ============================================================
// NOTIFICATIONS & ALERTS
// ============================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  factoryId String?
  type      NotificationType
  title     String
  message   String
  data      Json?
  priority  AlarmSeverity    @default(HIGH)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  emailSent Boolean          @default(false)
  smsSent   Boolean          @default(false)
  pushSent  Boolean          @default(false)
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  factory Factory? @relation(fields: [factoryId], references: [id])

  @@index([userId, isRead])
  @@index([factoryId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  ALARM
  DOWNTIME
  PRODUCTION
  QUALITY
  MAINTENANCE
  ENERGY
  SYSTEM
  INFO
}

model NotificationRule {
  id         String   @id @default(uuid())
  factoryId  String
  name       String
  module     String
  event      String
  condition  Json?
  channels   Json // email, sms, whatsapp, push
  recipients Json // userIds or roles
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  factory Factory @relation(fields: [factoryId], references: [id])

  @@map("notification_rules")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  factoryId  String?
  userId     String?
  action     String
  module     String
  entityType String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  factory Factory? @relation(fields: [factoryId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([factoryId, createdAt])
  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================================
// INVENTORY — RAW MATERIALS MASTER
// ============================================================

model RawMaterial {
  id                String   @id @default(uuid())
  factoryId         String
  code              String // SAP / internal material code
  name              String
  nameAr            String?
  description       String?
  category          String? // RAW, PACKAGING, CONSUMABLE, CHEMICAL, LABEL
  unit              String   @default("KG") // legacy text (kept in sync with unitRef.code)
  unitId            String? // FK to UnitOfMeasure (preferred)
  unitCost          Float?
  currentStock      Float    @default(0)
  reservedStock     Float    @default(0) // soft-reserved for active WOs
  minStock          Float    @default(0)
  maxStock          Float?
  reorderPoint      Float?
  storageLocation   String? // free-text (legacy)
  storageLocationId String? // FK to StorageLocation
  supplierName      String?
  leadTimeDays      Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  factory            Factory               @relation(fields: [factoryId], references: [id])
  storageLocationRef StorageLocation?      @relation(fields: [storageLocationId], references: [id])
  unitRef            UnitOfMeasure?        @relation(fields: [unitId], references: [id])
  materialLots       MaterialLot[]
  bomItems           BOMItem[]
  recipeIngredients  RecipeIngredient[]
  routingStepUses    RoutingStepMaterial[]

  @@unique([factoryId, code])
  @@map("raw_materials")
}

// ============================================================
// BILL OF MATERIALS (proper BOM linking SKU → RawMaterials)
// ============================================================

// How a BOM came to exist — the BOM is a *summary* of the manufacturing process.
enum BomSource {
  MANUAL // hand-entered lines (legacy flow)
  DERIVED_FROM_PROCESS // generated from RoutingStepMaterials of the linked process
  DRAFT_FOR_PROCESS // BOM entered first; a draft process was generated from it
}

model BOMHeader {
  id           String    @id @default(uuid())
  factoryId    String
  skuId        String
  version      String    @default("1.0")
  isActive     Boolean   @default(true)
  approvedAt   DateTime?
  approvedById String?
  notes        String?
  // Smart link: process = source of truth, BOM = derived summary
  processId    String?
  sourceType   BomSource @default(MANUAL)
  isStale      Boolean   @default(false) // process materials changed after derivation
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sku     SKU                   @relation(fields: [skuId], references: [id])
  process ManufacturingProcess? @relation(fields: [processId], references: [id], onDelete: SetNull)
  items   BOMItem[]

  @@unique([skuId, version])
  @@map("bom_headers")
}

model BOMItem {
  id            String  @id @default(uuid())
  bomId         String
  rawMaterialId String
  quantityPer   Float // quantity needed per 1 unit of finished product
  unit          String // legacy text (kept in sync with unitRef.code)
  unitId        String? // FK to UnitOfMeasure (preferred)
  scrapFactor   Float   @default(0) // additional scrap % (0.05 = 5%)
  isOptional    Boolean @default(false)
  notes         String?
  routingStepId String? // which routing step consumes this line (set when derived)

  bom            BOMHeader      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterial    RawMaterial    @relation(fields: [rawMaterialId], references: [id])
  unitRef        UnitOfMeasure? @relation(fields: [unitId], references: [id])
  routingStepRef RoutingStep?   @relation(fields: [routingStepId], references: [id], onDelete: SetNull)

  @@map("bom_items")
}

// ============================================================
// STOCK MOVEMENTS (universal ledger for all inventory moves)
// ============================================================

model StockMovement {
  id              String          @id @default(uuid())
  factoryId       String
  entityType      StockEntityType
  entityId        String // sparePartId or rawMaterialId
  entityCode      String
  entityName      String
  movementType    MovementType
  quantity        Float // positive = in, negative = out (for ISSUE/CONSUMPTION)
  unitCost        Float?
  totalCost       Float?
  stockBefore     Float?
  stockAfter      Float?
  referenceType   String? // MAINTENANCE_WO, PRODUCTION_WO, PURCHASE_ORDER, ADJUSTMENT
  referenceId     String?
  referenceNumber String?
  performedById   String?
  notes           String?
  createdAt       DateTime        @default(now())

  factory     Factory @relation(fields: [factoryId], references: [id])
  performedBy User?   @relation("StockMovementBy", fields: [performedById], references: [id])

  @@index([factoryId, createdAt])
  @@index([entityType, entityId])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

enum StockEntityType {
  SPARE_PART
  RAW_MATERIAL
  PRODUCT
}

enum MovementType {
  RECEIPT // incoming stock (purchase, transfer in)
  ISSUE // outgoing (to maintenance WO, to production)
  RETURN // returned unused stock
  ADJUSTMENT // manual count adjustment
  RESERVATION // soft reserve (pending approval)
  RELEASE // release reservation (WO cancelled)
  CONSUMPTION // production consumption
}

// ============================================================
// TRACEABILITY — PLATFORM-WIDE EVENT LOG
// ============================================================

model TraceEvent {
  id        String  @id @default(uuid())
  factoryId String?

  // Entity this event concerns
  entityType String // MAINT_WO, PROD_WO, BATCH, SPARE_PART, RAW_MATERIAL, MACHINE, PRODUCT
  entityId   String
  entityCode String? // human-readable code/number

  // Event description
  eventType String // CREATED, STATUS_CHANGED, PARTS_REQUESTED, PARTS_ISSUED, STOCK_IN, STOCK_OUT, CONSUMED, RELEASED, etc.
  fromValue String? // previous status / quantity
  toValue   String? // new status / quantity
  quantity  Float?
  eventData Json? // arbitrary extra metadata

  // Who/when/where
  performedById String?
  performedAt   DateTime @default(now())
  notes         String?

  // Optional cross-reference (e.g., spare part issued TO a maintenance WO)
  relatedType String?
  relatedId   String?

  factory     Factory? @relation(fields: [factoryId], references: [id])
  performedBy User?    @relation("TracePerformedBy", fields: [performedById], references: [id])

  @@index([entityType, entityId])
  @@index([factoryId, performedAt])
  @@index([performedAt])
  @@map("trace_events")
}

// ============================================================
// TRACEABILITY GENEALOGY (parent-child edge table)
// Enables backward (root cause) and forward (recall) tracing
// ============================================================

enum TraceEntityType {
  MATERIAL_LOT // incoming raw material / packaging lot
  WORK_ORDER // production work order
  FINISHED_GOODS_LOT // completed product batch
  RECIPE // recipe version used
}

enum TraceLinkType {
  CONSUMED_BY // MATERIAL_LOT → WORK_ORDER (material was consumed in WO)
  PRODUCED_FROM // WORK_ORDER → FINISHED_GOODS_LOT (WO produced this FG lot)
  GOVERNED_BY // WORK_ORDER → RECIPE (WO was executed against this recipe)
}

model TraceabilityLink {
  id         String          @id @default(uuid())
  factoryId  String
  parentType TraceEntityType // the source entity
  parentId   String // FK into the relevant table (materialLotId, workOrderId, etc.)
  childType  TraceEntityType // the destination entity
  childId    String
  linkType   TraceLinkType
  qty        Float? // quantity consumed/produced
  unit       String?
  createdAt  DateTime        @default(now())

  factory Factory @relation(fields: [factoryId], references: [id])

  @@index([parentId])
  @@index([childId])
  @@index([factoryId, createdAt])
  @@map("traceability_links")
}

// ============================================================
// STORAGE LOCATIONS
// ============================================================

enum StorageZone {
  RAW_MATERIAL // RM warehouse
  FINISHED_GOODS // FG warehouse
  SPARE_PARTS // maintenance parts room
  QUARANTINE // QC hold / reject area
  PRODUCTION // line-side staging
  DISPATCH // shipping/dispatch bay
}

model StorageLocation {
  id          String      @id @default(uuid())
  factoryId   String
  code        String // e.g. "RM-A01", "SP-B03"
  name        String
  zone        StorageZone
  description String?
  capacity    Float? // max units / pallets / kg — optional
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  factory      Factory       @relation(fields: [factoryId], references: [id])
  rawMaterials RawMaterial[]
  materialLots MaterialLot[]
  spareParts   SparePart[]
  skus         SKU[]

  @@unique([factoryId, code])
  @@map("storage_locations")
}

// ============================================================
// MANUFACTURING PROCESSES & ROUTING
// ============================================================

model ManufacturingProcess {
  id                 String    @id @default(uuid())
  factoryId          String
  skuId              String? // set when scopeType = PRODUCT (legacy single-product routing)
  version            String    @default("1.0")
  name               String
  description        String?
  totalCycleTimeMins Float?
  isActive           Boolean   @default(true)
  approvedAt         DateTime?
  approvedById       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Scope: which products this routing applies to
  scopeType    ProcessScope @default(PRODUCT)
  categoryId   String? // scopeType = CATEGORY → all SKUs of this category
  baseWeightId String? // scopeType = BASE_WEIGHT → all SKUs of this weight

  factory       Factory                   @relation(fields: [factoryId], references: [id])
  sku           SKU?                      @relation(fields: [skuId], references: [id])
  categoryRef   ProductCategory?          @relation(fields: [categoryId], references: [id])
  baseWeightRef BaseWeight?               @relation(fields: [baseWeightId], references: [id])
  skuLinks       ManufacturingProcessSku[] // scopeType = PRODUCT_LIST
  routingSteps   RoutingStep[]
  recipes        Recipe[]
  derivedBoms    BOMHeader[]
  changeRequests ChangeRequest[]

  @@unique([skuId, version])
  @@map("manufacturing_processes")
}

enum ProcessScope {
  PRODUCT // one SKU
  CATEGORY // every SKU in a category
  BASE_WEIGHT // every SKU with the same base weight
  PRODUCT_LIST // explicit SKU list
}

// Join table for PRODUCT_LIST scope
model ManufacturingProcessSku {
  id        String @id @default(uuid())
  processId String
  skuId     String

  process ManufacturingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  sku     SKU                  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([processId, skuId])
  @@map("manufacturing_process_skus")
}

model RoutingStep {
  id            String   @id @default(uuid())
  processId     String
  stepNumber    Int
  operationName String // e.g. "Mixing", "Filling", "Capping", "Labelling", "Packaging"
  workCenter    String? // machine / area code
  machineId     String?
  cycleTimeSec  Float? // PRIMARY reference for job-order cycle time & duration
  cycleTimeMins Float? // legacy (auto-derived = cycleTimeSec/60)
  setupTimeMins Float?
  // Unit flow: what the step consumes/produces (BaseUnit codes: PCS/INNER/CARTON/PALLET).
  // cycleTimeSec is "seconds per ONE outUnit" — scheduling converts the order
  // quantity through the SKU packaging hierarchy to get the true duration.
  inUnit        String?
  outUnit       String?
  description   String?
  parameters    Json? // process parameters: { temperature: 80, pressure: 2.5 }
  isOptional    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workCenterId String? // FK to WorkCenter (logical routing cell)

  process        ManufacturingProcess       @relation(fields: [processId], references: [id], onDelete: Cascade)
  machine        Machine?                   @relation(fields: [machineId], references: [id])
  workCenterRef  WorkCenter?                @relation(fields: [workCenterId], references: [id])
  predecessors   StepDependency[]           @relation("DepTo")
  successors     StepDependency[]           @relation("DepFrom")
  jobOrders      JobOrder[]
  materials      RoutingStepMaterial[]
  machineOptions RoutingStepMachineOption[]
  bomItems       BOMItem[]

  @@unique([processId, stepNumber])
  @@map("routing_steps")
}

// Primary + alternative machines for a routing step. priority 0 = primary/default;
// 1+ = alternatives in preference order. Auto-assignment at WO generation picks the
// default when idle, otherwise the earliest-finishing alternative (wait + setup + run).
model RoutingStepMachineOption {
  id            String   @id @default(uuid())
  stepId        String
  machineId     String
  priority      Int      @default(1)
  isDefault     Boolean  @default(false)
  cycleTimeSec  Float? // override: this machine may run slower/faster than the step default
  setupTimeMins Float? // changeover penalty when switching to this machine
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  step    RoutingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  machine Machine     @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([stepId, machineId])
  @@index([stepId])
  @@map("routing_step_machine_options")
}

// Input raw materials consumed by a routing step.
// qtyPerOutputUnit = quantity needed to produce ONE outUnit of the step —
// completion writes real MaterialConsumption rows (qty × produced output)
// feeding Traceability & Genealogy.
model RoutingStepMaterial {
  id               String   @id @default(uuid())
  stepId           String
  rawMaterialId    String? // optional link to the raw-materials master
  materialCode     String?
  name             String
  qtyPerOutputUnit Float
  unit             String   @default("KG") // legacy text (kept in sync with unitRef.code)
  unitId           String? // FK to UnitOfMeasure (preferred; auto-fetched from raw material)
  createdAt        DateTime @default(now())

  step        RoutingStep    @relation(fields: [stepId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial?   @relation(fields: [rawMaterialId], references: [id], onDelete: SetNull)
  unitRef     UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([stepId])
  @@map("routing_step_materials")
}

// ============================================================
// SHARED ENUMS
// ============================================================

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// WORKCENTER HIERARCHY (ISA-95 Level 1-3)
// ============================================================

enum WorkCenterLevel {
  PLANT // Level 0 – entire site
  AREA // Level 1 – e.g. Mixing Hall, Filling Hall
  LINE // Level 2 – production line within an area
  CELL // Level 3 – individual station / work cell
}

model WorkCenter {
  id          String          @id @default(uuid())
  factoryId   String
  parentId    String? // null = root (PLANT level)
  code        String // e.g. "WC-MIX-A01"
  name        String // e.g. "Mixing Cell A"
  level       WorkCenterLevel
  description String?
  capacity    Float? // units/hour capacity
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  factory        Factory         @relation(fields: [factoryId], references: [id])
  parent         WorkCenter?     @relation("WCHierarchy", fields: [parentId], references: [id])
  children       WorkCenter[]    @relation("WCHierarchy")
  routingSteps   RoutingStep[]
  downtimeEvents DowntimeEvent[] @relation("WCDowntimes")
  energyReadings EnergyReading[] @relation("WCEnergyReadings")
  jobOrders      JobOrder[]

  @@unique([factoryId, code])
  @@map("work_centers")
}

// ============================================================
// STEP DEPENDENCIES (FS / SS / SF / FF)
// ============================================================

enum DependencyType {
  FINISH_TO_START // B cannot start until A finishes (default)
  START_TO_START // B cannot start until A starts
  START_TO_FINISH // B cannot finish until A starts
  FINISH_TO_FINISH // B cannot finish until A finishes
}

model StepDependency {
  id         String         @id @default(uuid())
  fromStepId String // predecessor step
  toStepId   String // successor step
  type       DependencyType @default(FINISH_TO_START)
  lagMins    Float          @default(0) // positive = lag, negative = lead

  fromStep RoutingStep @relation("DepFrom", fields: [fromStepId], references: [id], onDelete: Cascade)
  toStep   RoutingStep @relation("DepTo", fields: [toStepId], references: [id], onDelete: Cascade)

  @@unique([fromStepId, toStepId])
  @@map("step_dependencies")
}

// ============================================================
// RECIPE (Master Production Document)
// ============================================================

enum RecipeStatus {
  DRAFT // being authored
  REVIEW // submitted for approval
  APPROVED // production-ready
  OBSOLETE // superseded by newer version
}

model Recipe {
  id                String       @id @default(uuid())
  factoryId         String
  skuId             String
  processId         String? // linked ManufacturingProcess (routing)
  code              String // e.g. "RCP-ALWATANI-001"
  version           String       @default("1.0")
  name              String
  description       String?
  status            RecipeStatus @default(DRAFT)
  batchSize         Float? // target batch size (e.g. 1000 KG)
  batchUnit         String? // e.g. KG, L, PCS
  yieldPct          Float? // expected yield %
  cycleTimeSecs     Float? // target cycle time per batch
  shelfLifeDays     Int?
  storageConditions String? // e.g. "Cool, dry, away from direct sunlight"
  approvedAt        DateTime?
  approvedById      String?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  factory     Factory               @relation(fields: [factoryId], references: [id])
  sku         SKU                   @relation(fields: [skuId], references: [id])
  process     ManufacturingProcess? @relation(fields: [processId], references: [id])
  approvedBy  User?                 @relation("RecipeApprovedBy", fields: [approvedById], references: [id])
  ingredients RecipeIngredient[]
  workOrders  WorkOrder[]

  @@unique([skuId, version])
  @@map("recipes")
}

model RecipeIngredient {
  id            String  @id @default(uuid())
  recipeId      String
  rawMaterialId String
  phase         String? // e.g. "Premix A", "Main Mix", "Top-up"
  quantityPer   Float // quantity per batch
  unit          String
  scrapFactor   Float   @default(0) // % waste allowance
  isOptional    Boolean @default(false)
  notes         String?
  sortOrder     Int     @default(0)

  recipe      Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@map("recipe_ingredients")
}

// ============================================================
// JOB ORDER (ISA-95 Part 2 — Dispatch List)
// One JobOrder per RoutingStep per WorkOrder.
// Represents the atomic unit of work assigned to one machine
// for one operation segment of the production run.
// ============================================================

enum JobOrderStatus {
  SCHEDULED // created, not yet ready to start (predecessor incomplete)
  READY // predecessor handover criteria met — operator can start
  EXECUTING // machine actively running this step
  PAUSED // temporarily interrupted
  COMPLETE // step finished, output confirmed
  CANCELLED
}

model JobOrder {
  id            String         @id @default(uuid())
  factoryId     String
  workOrderId   String
  routingStepId String? // link to ManufacturingProcess RoutingStep
  machineId     String?
  workCenterId  String?
  sequenceOrder Int // mirrors RoutingStep.stepNumber
  operationName String // e.g. "Filling", "Cartoning", "Check-weigh"
  status        JobOrderStatus @default(SCHEDULED)

  // Predecessor chain — JO[N] becomes READY when JO[N-1] signals COMPLETE
  predecessorId      String?
  predecessorType    DependencyType @default(FINISH_TO_START) // FS/SS/SF/FF vs predecessor
  predecessorLagMins Float          @default(0) // +lag / −lead minutes

  // Schedule
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?

  // Quantities
  plannedQtyIn      Float? // input quantity planned
  plannedQtyOut     Float? // expected output quantity
  actualQtyGood     Float   @default(0)
  actualQtyRejected Float   @default(0)
  handoverQty       Float   @default(0) // qty actually transferred to next step
  handoverCriteria  Float? // min qty before successor becomes READY
  outputUnit        String? // PIECE, CARTON, PALLET — unit of plannedQtyOut / actualQtyGood
  inputUnit         String? // unit of plannedQtyIn (step's consumed unit)

  // OEE denominator — stamped from MachineCycleTime at JO creation
  idealCycleTimeSec Float?

  operatorId  String? // assigned shop floor operator
  scrapReason String? // reason for actualQtyRejected

  // Intelligent machine allocation audit trail
  assignmentReason String? // DEFAULT_IDLE | DEFAULT_BUSY_ALT_SELECTED | MANUAL | HEURISTIC

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factory     Factory            @relation(fields: [factoryId], references: [id])
  workOrder   WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  routingStep RoutingStep?       @relation(fields: [routingStepId], references: [id])
  machine     Machine?           @relation(fields: [machineId], references: [id])
  workCenter  WorkCenter?        @relation(fields: [workCenterId], references: [id])
  predecessor JobOrder?          @relation("JOChain", fields: [predecessorId], references: [id])
  successors  JobOrder[]         @relation("JOChain")
  materials   JobOrderMaterial[]
  operator    User?              @relation("JOOperator", fields: [operatorId], references: [id])
  scrapLogs   ScrapLog[]

  @@index([workOrderId])
  @@index([factoryId, status])
  @@index([machineId])
  @@map("job_orders")
}

// Per-step scrap / rejection log — every increment of actualQtyRejected creates one entry
model ScrapLog {
  id          String        @id @default(uuid())
  factoryId   String
  workOrderId String
  jobOrderId  String
  operatorId  String?
  qty         Float
  reason      String
  category    ScrapCategory @default(OTHER)
  notes       String?
  createdAt   DateTime      @default(now())

  factory   Factory   @relation(fields: [factoryId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  jobOrder  JobOrder  @relation(fields: [jobOrderId], references: [id])
  operator  User?     @relation("ScrapLogOperator", fields: [operatorId], references: [id])

  @@index([factoryId, createdAt])
  @@index([jobOrderId])
  @@index([workOrderId])
  @@map("scrap_logs")
}

enum ScrapCategory {
  QUALITY // Failed quality / spec out-of-range
  SETUP // Machine setup / startup waste
  DAMAGE // Physical handling damage
  OVERRUN // Weight / fill overrun
  MATERIAL // Raw material defect
  MACHINE // Machine malfunction
  OPERATOR // Operator error
  OTHER
}

// Per-step material specification: inputs consumed and outputs produced
model JobOrderMaterial {
  id            String  @id @default(uuid())
  jobOrderId    String
  materialCode  String
  materialName  String
  direction     String // IN | OUT | REJECT
  materialLotId String?
  plannedQty    Float
  actualQty     Float   @default(0)
  unit          String

  jobOrder    JobOrder     @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  materialLot MaterialLot? @relation(fields: [materialLotId], references: [id])

  @@index([jobOrderId])
  @@map("job_order_materials")
}

// ════════════════════════════════════════════════════════════════
// DASHBOARD CENTER — unified dashboard catalog & launcher
// STAR-MES = system of record / auth / factory context.
// Grafana   = visualization & dashboard engine (linked, not rebuilt).
// Models are intentionally isolated (plain indexed FKs) to remain
// fully additive — no changes to existing core models.
// ════════════════════════════════════════════════════════════════

enum DashboardSource {
  STAR_MES_NATIVE // existing in-app module dashboards / analytics pages
  GRAFANA // Grafana-hosted dashboard (embedded)
  REPORT // existing STAR-MES report pages
  EXTERNAL // arbitrary external/embeddable URL
  TEMPLATE // reusable dashboard template (clone to create)
}

enum DashboardType {
  OPERATIONAL
  KPI
  ANALYTICS
  REPORT
  EXECUTIVE
  ENERGY
  QUALITY
  MAINTENANCE
  PRODUCTION
  CUSTOM
}

enum DashboardVisibility {
  PRIVATE // only the creator
  FACTORY // everyone in the same factory
  ENTERPRISE // everyone in the enterprise
  PUBLIC // any authenticated user
}

enum DashboardPermissionLevel {
  VIEW
  EDIT
  MANAGE
}

model DashboardCategory {
  id          String   @id @default(uuid())
  factoryId   String? // null = global / enterprise-wide category
  key         String // stable slug e.g. "production", "energy"
  name        String
  nameAr      String?
  description String?
  icon        String? // lucide icon name
  color       String?
  sortOrder   Int      @default(0)
  isSystem    Boolean  @default(false) // seeded, non-deletable
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dashboards Dashboard[]

  @@unique([factoryId, key])
  @@index([factoryId])
  @@map("dashboard_categories")
}

model Dashboard {
  id           String              @id @default(uuid())
  factoryId    String? // null = global/enterprise dashboard (visible across factories)
  enterpriseId String?
  categoryId   String?
  slug         String? // optional stable slug for deep-linking
  title        String
  titleAr      String?
  description  String?
  source       DashboardSource     @default(STAR_MES_NATIVE)
  type         DashboardType       @default(OPERATIONAL)
  visibility   DashboardVisibility @default(FACTORY)

  // Native / external routing
  route       String? // internal Next.js route, e.g. "/production/oee"
  externalUrl String? // external embeddable URL (EXTERNAL source)

  // Grafana linkage
  grafanaUid    String? // Grafana dashboard UID
  grafanaSlug   String?
  grafanaOrgId  Int?
  grafanaFolder String?

  // Presentation / behavior
  icon             String? // lucide icon name
  thumbnailUrl     String?
  tags             String[] @default([])
  isFactoryAware   Boolean  @default(true) // inherit selected factory context
  supportedScopes  String[] @default([]) // e.g. ["FACTORY","AREA","LINE","MACHINE","SHIFT","PRODUCT","BATCH"]
  defaultTimeRange String?  @default("now-24h")
  refreshInterval  String?  @default("30s")

  // Template support
  isTemplate   Boolean @default(false)
  templateOfId String? // if cloned from a template

  // Governance
  isSystem     Boolean   @default(false) // seeded built-in, non-deletable
  isPublished  Boolean   @default(true)
  createdById  String?
  updatedById  String?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category    DashboardCategory?    @relation(fields: [categoryId], references: [id])
  favorites   DashboardFavorite[]
  permissions DashboardPermission[]

  @@index([factoryId, source])
  @@index([categoryId])
  @@index([type])
  @@index([isTemplate])
  @@map("dashboards")
}

model DashboardFavorite {
  id          String   @id @default(uuid())
  dashboardId String
  userId      String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@unique([dashboardId, userId])
  @@index([userId])
  @@map("dashboard_favorites")
}

model DashboardPermission {
  id          String                   @id @default(uuid())
  dashboardId String
  // Exactly one of role / userId is set (a grant either targets a role or a specific user)
  role        UserRole?
  userId      String?
  level       DashboardPermissionLevel @default(VIEW)
  createdAt   DateTime                 @default(now())

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@index([userId])
  @@map("dashboard_permissions")
}
