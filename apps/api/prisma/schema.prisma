// ============================================================
// STAR-MES Platform — Prisma Schema
// ISA-95 Compliant Enterprise Manufacturing Execution System
// National Care Company (NCC) — KSA Industrial Network
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ISA-95 LEVEL 4 — ENTERPRISE
// ============================================================

model Enterprise {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  nameAr    String?
  industry  String?
  country   String   @default("SA")
  timezone  String   @default("Asia/Riyadh")
  currency  String   @default("SAR")
  language  String   @default("en")
  logoUrl   String?
  isActive  Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  factories Factory[]
  users     User[]

  @@map("enterprises")
}

// ============================================================
// ISA-95 LEVEL 3 — FACTORY (SITE)
// ============================================================

model Factory {
  id           String   @id @default(uuid())
  enterpriseId String
  code         String   @unique
  name         String
  nameAr       String?
  city         String?
  country      String   @default("SA")
  address      String?
  lat          Float?
  lng          Float?
  color        String   @default("#00C8FF")
  glowColor    String   @default("rgba(0,200,255,0.3)")
  timezone     String   @default("Asia/Riyadh")
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enterprise             Enterprise             @relation(fields: [enterpriseId], references: [id])
  areas                  Area[]
  productionLines        ProductionLine[]
  machines               Machine[]
  users                  User[]
  skus                   SKU[]
  productCategories      ProductCategory[]
  productBrands          ProductBrand[]
  packagingTypes         PackagingType[]
  baseUnits              BaseUnit[]
  baseWeights            BaseWeight[]
  unitsOfMeasure         UnitOfMeasure[]
  changeRequests         ChangeRequest[]
  shifts                 ShiftTemplate[]
  shiftInstances         ShiftInstance[]
  productionOrders       ProductionOrder[]
  workOrders             WorkOrder[]
  batchRecords           BatchRecord[]
  materialLots           MaterialLot[]
  rawMaterials           RawMaterial[]
  storageLocations       StorageLocation[]
  stockMovements         StockMovement[]
  traceEvents            TraceEvent[]
  downtimeCauses         DowntimeCause[]
  downtimeEvents         DowntimeEvent[]
  oeeRecords             OEERecord[]
  machineStates          MachineStateRecord[]
  qualityPlans           QualityPlan[]
  inspectionResults      InspectionResult[]
  ncrs                   NCR[]
  capas                  CAPA[]
  spcMeasurements        SPCMeasurement[]
  maintenanceWOs         MaintenanceWO[]
  pmPlans                PMPlan[]
  pmTasks                PMTask[]
  spareParts             SparePart[]
  manufacturingProcesses ManufacturingProcess[]
  energyMeters           EnergyMeter[]
  energyReadings         EnergyReading[]
  energySummaries        EnergySummary[]
  devices                Device[]
  tagDefinitions         TagDefinition[]
  alarmDefinitions       AlarmDefinition[]
  alarmEvents            AlarmEvent[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  notificationRules      NotificationRule[]
  workCenters            WorkCenter[]
  recipes                Recipe[]
  energyWOSummaries      EnergyWOSummary[]
  traceabilityLinks      TraceabilityLink[]
  jobOrders              JobOrder[]
  scrapLogs              ScrapLog[]

  @@map("factories")
}

// ============================================================
// ISA-95 LEVEL 3 — AREA (Making, Packing, Utility, Warehouse)
// ============================================================

model Area {
  id          String   @id @default(uuid())
  factoryId   String
  code        String
  name        String
  nameAr      String?
  type        AreaType @default(PACKING)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  factory         Factory          @relation(fields: [factoryId], references: [id])
  productionLines ProductionLine[]
  machines        Machine[]
  energyMeters    EnergyMeter[]

  @@unique([factoryId, code])
  @@map("areas")
}

enum AreaType {
  MAKING
  PACKING
  FILLING
  UTILITY
  WAREHOUSE
  LABORATORY
  OFFICE
}

// ============================================================
// ISA-95 LEVEL 3 — PRODUCTION LINE
// ============================================================

model ProductionLine {
  id          String   @id @default(uuid())
  factoryId   String
  areaId      String
  code        String
  name        String
  nameAr      String?
  type        LineType @default(PACKING)
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  factory        Factory         @relation(fields: [factoryId], references: [id])
  area           Area            @relation(fields: [areaId], references: [id])
  machines       Machine[]
  workOrders     WorkOrder[]
  shiftInstances ShiftInstance[]

  @@unique([factoryId, code])
  @@map("production_lines")
}

enum LineType {
  PACKING
  FILLING
  MAKING
  BLOW_MOLDING
  BLOW_FILM
  AEROSOL
  CUTTING_SEALING
  UTILITY
}

// ============================================================
// ISA-95 LEVEL 2 — MACHINE (EQUIPMENT)
// ============================================================

model Machine {
  id                String      @id @default(uuid())
  factoryId         String
  areaId            String?
  lineId            String?
  code              String
  name              String
  nameAr            String?
  sortOrder         Int         @default(0)
  machineType       MachineType @default(MACHINE)
  manufacturer      String?
  model             String?
  serialNumber      String?
  installDate       DateTime?
  warrantyExpiry    DateTime?
  criticality       Criticality @default(MEDIUM)
  designCapacity    Float? // units per hour
  downtimeThreshold Int         @default(60) // seconds before classifying as downtime
  isActive          Boolean     @default(true)
  metadata          Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  factory           Factory                    @relation(fields: [factoryId], references: [id])
  area              Area?                      @relation(fields: [areaId], references: [id])
  line              ProductionLine?            @relation(fields: [lineId], references: [id])
  currentStatus     MachineCurrentStatus?
  modules           MachineModule[]
  cycleTimes        MachineCycleTime[]
  downtimeCauses    DowntimeCause[]
  stateRecords      MachineStateRecord[]
  downtimeEvents    DowntimeEvent[]
  oeeRecords        OEERecord[]
  workOrders        WorkOrder[]
  maintenanceWOs    MaintenanceWO[]
  pmPlans           PMPlan[]
  pmTasks           PMTask[]
  runtimeHours      MachineRuntimeHours[]
  failureModes      FailureMode[]
  inspectionResults InspectionResult[]
  spcMeasurements   SPCMeasurement[]
  devices           Device[]
  tagDefinitions    TagDefinition[]
  alarmEvents       AlarmEvent[]
  energyMeters      EnergyMeter[]
  routingSteps      RoutingStep[]
  jobOrders         JobOrder[]
  stepOptions       RoutingStepMachineOption[]

  @@unique([factoryId, code])
  @@index([factoryId])
  @@index([lineId])
  @@map("machines")
}

enum MachineType {
  MACHINE
  PRODUCTION_LINE
  CONVEYOR
  ROBOT
  PALLETIZER
  CHECKWEIGHER
  FILLING_MACHINE
  CARTONING_MACHINE
  WRAPPING_MACHINE
  BLOW_MOLDING
  BLOW_FILM
  COMPRESSOR
  BOILER
  TRANSFORMER
  CHILLER
  ENERGY_METER
  PUMP
  MIXER
  REACTOR
  HMI
  GATEWAY
  SENSOR
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// ISA-95 LEVEL 1 — MACHINE MODULE
// ============================================================

model MachineModule {
  id          String   @id @default(uuid())
  machineId   String
  code        String
  name        String
  type        String? // DRIVE, SENSOR, VALVE, ACTUATOR, CONTROLLER
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([machineId, code])
  @@map("machine_modules")
}

// CURRENT STATUS — live snapshot
model MachineCurrentStatus {
  id              String       @id @default(uuid())
  machineId       String       @unique
  state           MachineState @default(OFFLINE)
  currentSKUId    String?
  currentWOId     String?
  oee             Float?
  availability    Float?
  performance     Float?
  quality         Float?
  actualSpeed     Float? // units/hour
  targetSpeed     Float?
  goodCount       Int          @default(0)
  rejectCount     Int          @default(0)
  downtimeMinutes Float        @default(0)
  runtimeMinutes  Float        @default(0)
  lastEventAt     DateTime?
  updatedAt       DateTime     @updatedAt

  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@map("machine_current_status")
}

enum MachineState {
  RUNNING
  IDLE
  PLANNED_STOP
  BREAKDOWN
  SETUP
  CHANGEOVER
  STARVED
  BLOCKED
  OFFLINE
  MAINTENANCE
}

// ============================================================
// MACHINE CYCLE TIME (per SKU per machine — from NCC data)
// ============================================================

model MachineCycleTime {
  id               String   @id @default(uuid())
  machineId        String
  skuId            String
  cycleTimeSeconds Int
  unitType         String   @default("UNIT") // UNIT, INNER, CARTON, PALLET
  maxSpeed         Float? // units per hour (theoretical max)
  source           String   @default("NCC_DATA") // NCC_DATA, MEASURED, CALCULATED
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  machine Machine @relation(fields: [machineId], references: [id])
  sku     SKU     @relation(fields: [skuId], references: [id])

  @@unique([machineId, skuId, unitType])
  @@map("machine_cycle_times")
}

// ============================================================
// PRODUCT & SKU MASTER DATA
// ============================================================

model ProductFamily {
  id        String   @id @default(uuid())
  factoryId String
  code      String
  name      String
  nameAr    String?
  brand     String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  skus SKU[]

  @@unique([factoryId, code])
  @@map("product_families")
}

// ── PLM ENGINEERING CHANGE REQUESTS ──────────────────────────────────────────
enum ChangeRequestType {
  BOM_CHANGE
  RECIPE_CHANGE
  PROCESS_CHANGE
  DESIGN_CHANGE
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

model ChangeRequest {
  id            String              @id @default(uuid())
  factoryId     String
  crNumber      String // ECR-2026-001
  title         String
  description   String?
  type          ChangeRequestType
  status        ChangeRequestStatus @default(DRAFT)
  priority      Priority            @default(MEDIUM)
  skuId         String? // affected product
  processId     String? // affected manufacturing process (PROCESS_CHANGE governance)
  requestedById String?
  reviewedById  String?
  reason        String?
  targetDate    DateTime?
  implementedAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  factory     Factory               @relation(fields: [factoryId], references: [id])
  sku         SKU?                  @relation(fields: [skuId], references: [id])
  process     ManufacturingProcess? @relation(fields: [processId], references: [id], onDelete: SetNull)
  requestedBy User?                 @relation("CRRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?                 @relation("CRReviewedBy", fields: [reviewedById], references: [id])

  @@unique([factoryId, crNumber])
  @@index([factoryId, status])
  @@map("change_requests")
}

// ── PRODUCT MASTER DATA (managed lookups powering the product form) ─────────
model ProductCategory {
  id        String   @id @default(uuid())
  factoryId String
  name      String
  nameAr    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  factory   Factory                @relation(fields: [factoryId], references: [id])
  skus      SKU[]
  processes ManufacturingProcess[]

  @@unique([factoryId, name])
  @@map("product_categories")
}

model ProductBrand {
  id        String   @id @default(uuid())
  factoryId String
  name      String
  nameAr    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  factory Factory @relation(fields: [factoryId], references: [id])
  skus    SKU[]

  @@unique([factoryId, name])
  @@map("product_brands")
}

model PackagingType {
  id        String   @id @default(uuid())
  factoryId String
  name      String
  nameAr    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  factory Factory @relation(fields: [factoryId], references: [id])
  skus    SKU[]

  @@unique([factoryId, name])
  @@map("packaging_types")
}

model BaseUnit {
  id        String   @id @default(uuid())
  factoryId String
  code      String // PCS, CARTON, PALLET, KG …
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  factory Factory @relation(fields: [factoryId], references: [id])
  skus    SKU[]

  @@unique([factoryId, code])
  @@map("base_units")
}

model BaseWeight {
  id        String   @id @default(uuid())
  factoryId String
  value     Float // e.g. 2.25
  unit      String   @default("kg")
  label     String? // e.g. "2.25 Kg"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  factory   Factory                @relation(fields: [factoryId], references: [id])
  skus      SKU[]
  processes ManufacturingProcess[]

  @@unique([factoryId, value, unit])
  @@map("base_weights")
}

// ============================================================
// UNIFIED UNIT OF MEASURE (canonical units + conversion factors)
// Single source of truth for units across raw materials, BOM lines,
// routing-step materials and material lots. PACKAGING-category units
// (INNER/CARTON/PALLET) convert through the SKU packaging ladder, not factors.
// ============================================================

enum UomCategory {
  WEIGHT
  VOLUME
  COUNT
  PACKAGING
  LENGTH
  AREA
  TIME
}

model UnitOfMeasure {
  id               String      @id @default(uuid())
  factoryId        String
  code             String // KG, G, TON, L, ML, PCS, INNER, CARTON, PALLET, ROLL, M
  name             String
  nameAr           String?
  category         UomCategory
  baseUnitCode     String? // canonical unit of the category (KG / L / PCS)
  conversionFactor Float       @default(1) // 1 of this unit = factor × baseUnitCode (G = 0.001 KG)
  decimals         Int         @default(3)
  sortOrder        Int         @default(0)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  factory              Factory               @relation(fields: [factoryId], references: [id])
  rawMaterials         RawMaterial[]
  bomItems             BOMItem[]
  routingStepMaterials RoutingStepMaterial[]
  materialLots         MaterialLot[]

  @@unique([factoryId, code])
  @@map("units_of_measure")
}

model SKU {
  id               String   @id @default(uuid())
  factoryId        String
  familyId         String?
  itemNumber       String // NCC SAP item number (e.g. 10310064)
  code             String // Internal code
  name             String
  nameAr           String?
  shortName        String?
  brand            String? // legacy text (kept in sync with brandRef.name)
  category         String? // legacy text (kept in sync with categoryRef.name)
  // Master-data relations (preferred; the legacy strings stay synced)
  categoryId       String?
  brandId          String?
  packagingTypeId  String?
  baseUnitId       String?
  baseWeightId     String?
  weight           Float?
  weightUnit       String   @default("kg")
  length           Float?
  width            Float?
  height           Float?
  dimensionUnit    String   @default("cm")
  packagingType    String? // legacy text (kept in sync with packagingTypeRef.name)
  unitsPerInner    Int      @default(1)
  innersPerCarton  Int      @default(1)
  cartonsPerPallet Int      @default(1)
  baseUnit         String   @default("EA") // legacy text (kept in sync with baseUnitRef.code)
  isActive         Boolean  @default(true)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  storageLocationId String? // FK to StorageLocation (finished goods / dispatch)

  factory                Factory                   @relation(fields: [factoryId], references: [id])
  family                 ProductFamily?            @relation(fields: [familyId], references: [id])
  storageLocationRef     StorageLocation?          @relation(fields: [storageLocationId], references: [id])
  categoryRef            ProductCategory?          @relation(fields: [categoryId], references: [id])
  brandRef               ProductBrand?             @relation(fields: [brandId], references: [id])
  packagingTypeRef       PackagingType?            @relation(fields: [packagingTypeId], references: [id])
  baseUnitRef            BaseUnit?                 @relation(fields: [baseUnitId], references: [id])
  baseWeightRef          BaseWeight?               @relation(fields: [baseWeightId], references: [id])
  cycleTimes             MachineCycleTime[]
  bomComponents          BOMComponent[]
  bomHeaders             BOMHeader[]
  workOrders             WorkOrder[]
  productionOrders       ProductionOrder[]
  batchRecords           BatchRecord[]
  manufacturingProcesses ManufacturingProcess[]
  processLinks           ManufacturingProcessSku[]
  recipes                Recipe[]
  changeRequests         ChangeRequest[]

  @@unique([factoryId, itemNumber])
  @@index([factoryId])
  @@index([categoryId])
  @@index([baseWeightId])
  @@map("skus")
}

model BOMComponent {
  id            String   @id @default(uuid())
  skuId         String
  componentCode String
  componentName String
  quantity      Float
  unit          String
  type          String   @default("RAW") // RAW, PACKAGING, CONSUMABLE
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  sku SKU @relation(fields: [skuId], references: [id])

  @@map("bom_components")
}

// ============================================================
// PRODUCTION EXECUTION
// ============================================================

// PRODUCTION ORDER (ERP / SAP level)
model ProductionOrder {
  id             String                @id @default(uuid())
  factoryId      String
  orderNumber    String                @unique
  sapOrderNumber String?
  skuId          String?
  targetQty      Int
  completedQty   Int                   @default(0)
  unit           String                @default("CARTON")
  status         ProductionOrderStatus @default(PLANNED)
  // Rolled-up OEE from child work orders (engine: see docs/DESIGN-oee-kpi-engine.md)
  oee            Float?
  availability   Float?
  performance    Float?
  quality        Float?
  priority       Priority              @default(MEDIUM)
  plannedStart   DateTime
  plannedEnd     DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  customer       String?
  notes          String?
  sapSync        Boolean               @default(false)
  sapSyncedAt    DateTime?
  createdById    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?

  factory    Factory     @relation(fields: [factoryId], references: [id])
  sku        SKU?        @relation(fields: [skuId], references: [id])
  workOrders WorkOrder[]

  @@index([factoryId, status])
  @@map("production_orders")
}

enum ProductionOrderStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

// WORK ORDER (shop floor execution)
model WorkOrder {
  id                String          @id @default(uuid())
  factoryId         String
  productionOrderId String?
  lineId            String?
  machineId         String?
  skuId             String?
  shiftInstanceId   String?
  orderNumber       String          @unique
  status            WorkOrderStatus @default(PLANNED)
  priority          Priority        @default(MEDIUM)
  plannedQty        Int
  actualQty         Int             @default(0)
  goodQty           Int             @default(0)
  scrapQty          Int             @default(0)
  reworkQty         Int             @default(0)
  plannedStart      DateTime
  plannedEnd        DateTime
  actualStart       DateTime?
  actualEnd         DateTime?
  oee               Float?
  availability      Float?
  performance       Float?
  quality           Float?
  downtimeMinutes   Float           @default(0)
  plannedCycleTime  Float? // seconds per unit
  recipeId          String? // locked recipe at WO creation
  recipeVersion     String?
  notes             String?
  createdById       String?
  startedById       String?
  completedById     String?
  operatorId        String?
  supervisorId      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  factory              Factory               @relation(fields: [factoryId], references: [id])
  productionOrder      ProductionOrder?      @relation(fields: [productionOrderId], references: [id])
  line                 ProductionLine?       @relation(fields: [lineId], references: [id])
  machine              Machine?              @relation(fields: [machineId], references: [id])
  sku                  SKU?                  @relation(fields: [skuId], references: [id])
  shiftInstance        ShiftInstance?        @relation(fields: [shiftInstanceId], references: [id])
  createdBy            User?                 @relation("WOCreatedBy", fields: [createdById], references: [id])
  startedBy            User?                 @relation("WOStartedBy", fields: [startedById], references: [id])
  completedBy          User?                 @relation("WOCompletedBy", fields: [completedById], references: [id])
  operator             User?                 @relation("WOOperator", fields: [operatorId], references: [id])
  supervisor           User?                 @relation("WOSupervisor", fields: [supervisorId], references: [id])
  recipe               Recipe?               @relation(fields: [recipeId], references: [id])
  batchRecords         BatchRecord[]
  downtimeEvents       DowntimeEvent[]
  materialConsumptions MaterialConsumption[]
  productionEvents     ProductionEvent[]
  inspectionResults    InspectionResult[]
  energyWOSummary      EnergyWOSummary?
  maintenanceOrders    MaintenanceWO[]       @relation("MaintLinkedProdWO")
  jobOrders            JobOrder[]
  scrapLogs            ScrapLog[]

  @@index([factoryId, status])
  @@index([factoryId, plannedStart])
  @@index([machineId])
  @@map("work_orders")
}

enum WorkOrderStatus {
  PLANNED
  RELEASED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

// PRODUCTION EVENT (state changes, count updates, etc.)
model ProductionEvent {
  id          String              @id @default(uuid())
  factoryId   String
  workOrderId String?
  machineId   String?
  shiftId     String?
  eventType   ProductionEventType
  timestamp   DateTime            @default(now())
  value       Float?
  skuId       String?
  metadata    Json?

  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@index([factoryId, timestamp])
  @@index([machineId, timestamp])
  @@map("production_events")
}

enum ProductionEventType {
  WO_STARTED
  WO_COMPLETED
  WO_PAUSED
  COUNT_UPDATE
  SCRAP_RECORDED
  CHANGEOVER_START
  CHANGEOVER_END
  SHIFT_START
  SHIFT_END
  DOWNTIME_START
  DOWNTIME_END
  SPEED_CHANGE
  SKU_CHANGE
}

// ============================================================
// TRACEABILITY — BATCH / LOT RECORD
// ============================================================

model BatchRecord {
  id               String      @id @default(uuid())
  factoryId        String
  workOrderId      String?
  skuId            String?
  batchNumber      String      @unique
  lotNumber        String?
  status           BatchStatus @default(ACTIVE)
  quantity         Int
  goodQuantity     Int         @default(0)
  scrapQuantity    Int         @default(0)
  unit             String      @default("CARTON")
  startTime        DateTime?
  endTime          DateTime?
  expiryDate       DateTime?
  releaseDate      DateTime?
  releasedById     String?
  electronicRecord Json? // EBR — process parameters, checkpoints
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  factory              Factory               @relation(fields: [factoryId], references: [id])
  workOrder            WorkOrder?            @relation(fields: [workOrderId], references: [id])
  sku                  SKU?                  @relation(fields: [skuId], references: [id])
  materialConsumptions MaterialConsumption[]
  genealogyAsChild     GenealogyLink[]       @relation("ChildBatch")
  genealogyAsParent    GenealogyLink[]       @relation("ParentBatch")
  inspectionResults    InspectionResult[]

  @@index([factoryId])
  @@index([lotNumber])
  @@map("batch_records")
}

enum BatchStatus {
  ACTIVE
  COMPLETED
  RELEASED
  REJECTED
  ON_HOLD
  QUARANTINE
  DEPLETED // material lot fully consumed (remainingQty = 0)
}

// MATERIAL LOT (incoming raw materials, packaging)
model MaterialLot {
  id                String      @id @default(uuid())
  factoryId         String
  rawMaterialId     String? // optional link to RawMaterial master
  materialCode      String
  materialName      String
  lotNumber         String
  supplierLot       String?
  supplierId        String?
  supplierName      String?
  quantity          Float
  remainingQty      Float
  unit              String // legacy text (kept in sync with unitRef.code)
  unitId            String? // FK to UnitOfMeasure (preferred)
  status            BatchStatus @default(ACTIVE)
  receivedAt        DateTime    @default(now())
  expiryDate        DateTime?
  storageLocation   String? // free-text (legacy)
  storageLocationId String? // FK to StorageLocation
  binNumber         String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  factory            Factory               @relation(fields: [factoryId], references: [id])
