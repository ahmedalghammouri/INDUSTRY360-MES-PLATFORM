{
  "name": "@star-mes/edgegateway",
  "version": "1.0.0",
  "private": true,
  "description": "STAR-MES on-prem Edge Gateway — Modbus acquisition, edge counters, MQTT/Influx/Postgres ingest",
  "scripts": {
    "prisma:sync": "node scripts/sync-schema.mjs",
    "prisma:generate": "pnpm prisma:sync && prisma generate",
    "prebuild": "pnpm --filter @star-mes/industrial-drivers build && pnpm prisma:generate",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "pnpm prisma:generate && nest start --watch",
    "package:win": "pnpm build && pkg . --targets node20-win-x64 --output build/edgegateway.exe && node scripts/copy-runtime-assets.mjs",
    "type-check": "tsc --noEmit"
  },
  "bin": "dist/main.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/.prisma/client/*.node",
      "prisma/schema.prisma"
    ],
    "scripts": ["dist/**/*.js"]
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@prisma/client": "^5.19.0",
    "@star-mes/industrial-drivers": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "modbus-serial": "^8.0.17",
    "mqtt": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.3.0",
    "esbuild": "^0.24.0",
    "prisma": "^5.19.0",
    "typescript": "^5.5.0"
  }
}
