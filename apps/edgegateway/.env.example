# ── STAR-MES Edge Gateway configuration ───────────────────────────────
# Copy to `.env` next to the executable and adjust for the plant network.

# This gateway's identity (a Gateway row is upserted on startup)
GATEWAY_ID=
GATEWAY_NAME=Plant Edge Gateway 1
GATEWAY_FACTORY_CODE=NCC

# Local dashboard
GATEWAY_PORT=4900

# Shared platform services (point at the Docker host / server)
DATABASE_URL=postgresql://mes_user:mes_password@SERVER_HOST:5433/star_mes?schema=public
MQTT_BROKER_URL=mqtt://SERVER_HOST:1883
INFLUX_URL=http://SERVER_HOST:8086
INFLUX_TOKEN=mes-influx-super-secret-token
INFLUX_ORG=star-mes
INFLUX_BUCKET=mes_timeseries

# Must match the API so dashboard logins use the same users/JWT
JWT_SECRET=star-mes-jwt-secret-key-change-in-production-32charss

# Acquisition tuning
DEFAULT_POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=15000
# On-disk buffer used when a sink (DB/MQTT/Influx) is unreachable
BUFFER_DIR=./buffer
