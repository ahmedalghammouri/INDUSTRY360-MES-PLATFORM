# ============================================================
# STAR-MES production env — copy to `.env` next to
# docker-compose.prod.yml and fill in real secrets.
#   cp .env.prod.example .env   &&   edit .env
# ============================================================

# --- Docker Hub image source ---
DOCKER_NS=gemyalghammouri678
TAG=latest

# --- Public entrypoint (nginx host ports) ---
HTTP_PORT=80
HTTPS_PORT=443
# Public URL used for SSR fetches / OpenAPI server (no trailing slash)
PUBLIC_URL=https://mes.example.com
PUBLIC_WS_URL=wss://mes.example.com
# Comma-separated browser origins allowed by the API CORS
CORS_ORIGINS=https://mes.example.com

# --- Postgres ---
POSTGRES_DB=star_mes
POSTGRES_USER=mes_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# --- InfluxDB ---
INFLUX_USERNAME=admin
INFLUX_PASSWORD=CHANGE_ME_influx_admin_password
INFLUX_ORG=star-mes
INFLUX_BUCKET=mes_timeseries
INFLUX_TOKEN=CHANGE_ME_long_random_influx_token

# --- MinIO (object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# --- JWT (each must be >= 32 chars) ---
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_characters
