{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@industry360/ui": ["packages/ui/src/index.ts"],
      "@industry360/shared": ["packages/shared/src/index.ts"],
      "@industry360/types": ["packages/types/src/index.ts"],
      "@industry360/auth-utils": ["packages/auth-utils/src/index.ts"],
      "@industry360/api-sdk": ["packages/api-sdk/src/index.ts"]
    }
  }
}
